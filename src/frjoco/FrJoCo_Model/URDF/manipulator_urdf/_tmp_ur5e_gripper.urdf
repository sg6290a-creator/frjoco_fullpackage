<?xml version="1.0" encoding="utf-8"?>
<robot name="ur5e_gripper">

<!--Rotations
Clockwise 90: -1.57079632679
Counter Clockwise 90: 1.57079632679
180: 3.14159265359
-->

<!--Torque Limits
Robstride03: Rated Torque: 20Nm // Peak Torque: 60Nm >>> Set effort: 20*1.25=25Nm
Myactuator X4-36: Rated Torque: 10.5Nm // Peak Torque: 34Nm >>> Set effort: 10.5*1.25=13Nm
Dynaimxel XL330: Stall Torque 0.52Nm >> Set effort: 0.52*0.8=0.416Nm
-->
  <!-- ==================== UR5e Links ==================== -->
  <link name="base_link"/>

