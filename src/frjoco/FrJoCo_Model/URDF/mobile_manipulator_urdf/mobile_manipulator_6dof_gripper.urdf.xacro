<?xml version="1.0"?>
<robot name="frjoco_mobile_manipulator" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="can_interface" default="can2"/>
  <xacro:arg name="default_velocity" default="0.5"/>
  <xacro:arg name="arm_perf_log_every_n_cycles" default="0"/>
  <xacro:arg name="ros_position_offset_wrist_3_joint" default="0.0"/>
  <xacro:arg name="enable_arm_hardware" default="true"/>

  <xacro:arg name="port_front" default="/dev/ttyUSB0"/>
  <xacro:arg name="port_rear" default="/dev/ttyUSB1"/>
  <xacro:arg name="front_driver_id" default="1"/>
  <xacro:arg name="rear_driver_id" default="2"/>
  <xacro:arg name="mobile_baudrate" default="57600"/>
  <xacro:arg name="enable_mobile_hardware" default="true"/>

  <xacro:arg name="gripper_port" default="/dev/serial/by-id/usb-FTDI_USB__-__Serial_Converter_FTAO4ZHT-if00-port0"/>
  <xacro:arg name="gripper_baudrate" default="1000000"/>
  <xacro:arg name="gripper_id" default="15"/>
  <xacro:arg name="gripper_ping_on_activate" default="false"/>
  <xacro:arg name="enable_gripper_hardware" default="true"/>

  <xacro:arg name="arm_mount_x" default="0.200"/>
  <xacro:arg name="arm_mount_y" default="0.000"/>
  <xacro:arg name="arm_mount_z" default="0.235"/>
  <xacro:arg name="arm_mount_roll" default="0.000"/>
  <xacro:arg name="arm_mount_pitch" default="0.000"/>
  <xacro:arg name="arm_mount_yaw" default="3.1416"/>

  <xacro:arg name="gripper_mount_x" default="-0.020"/>
  <xacro:arg name="gripper_mount_y" default="0.000"/>
  <xacro:arg name="gripper_mount_z" default="0.000"/>
  <xacro:arg name="gripper_mount_roll" default="0.000"/>
  <xacro:arg name="gripper_mount_pitch" default="0.000"/>
  <xacro:arg name="gripper_mount_yaw" default="0.000"/>

  <xacro:arg name="d405_x" default="0.030"/>
  <xacro:arg name="d405_y" default="0.000"/>
  <xacro:arg name="d405_z" default="0.070"/>
  <xacro:arg name="d405_roll" default="0.000"/>
  <xacro:arg name="d405_pitch" default="0.000"/>
  <xacro:arg name="d405_yaw" default="0.000"/>

  <xacro:include filename="$(find frjoco_model)/URDF/mobile_urdf/mobile_base.xacro"/>

  <xacro:property name="arm_mesh_dir" value="package://manipulator_description/meshes/6dof"/>
  <xacro:property name="gripper_mesh_dir" value="package://manipulator_description/meshes/gripper_parallel"/>

  <material name="fr_white">
    <color rgba="0.92 0.92 0.88 1.0"/>
  </material>
  <material name="fr_red">
    <color rgba="0.92 0.92 0.88 1.0"/>
  </material>
  <material name="fr_grey">
    <color rgba="0.92 0.92 0.88 1.0"/>
  </material>

  <!-- Arm mount on the mobile chassis. The mobile base owns base_link. -->
  <joint name="mobile_arm_joint" type="fixed">
    <parent link="chassis_link"/>
    <child link="arm_base_link"/>
    <origin
      xyz="$(arg arm_mount_x) $(arg arm_mount_y) $(arg arm_mount_z)"
      rpy="$(arg arm_mount_roll) $(arg arm_mount_pitch) $(arg arm_mount_yaw)"/>
  </joint>

  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.065" length="0.010"/>
      </geometry>
      <material name="fr_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.065" length="0.010"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ==================== 6DOF arm ==================== -->
  <link name="base_link_inertia">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/base.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/base.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00443333156" ixy="0.0" ixz="0.0" iyy="0.00443333156" iyz="0.0" izz="0.0072"/>
    </inertial>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/shoulder.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/shoulder.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="3.7"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.010267495893" ixy="0.0" ixz="0.0" iyy="0.010267495893" iyz="0.0" izz="0.00666"/>
    </inertial>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/upperarm.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/upperarm.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="8.393"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.133885781862" ixy="0.0" ixz="0.0" iyy="0.133885781862" iyz="0.0" izz="0.0151074"/>
    </inertial>
  </link>

  <link name="forearm_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/forearm.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/forearm.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="2.275"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0312093550996" ixy="0.0" ixz="0.0" iyy="0.0312093550996" iyz="0.0" izz="0.004095"/>
    </inertial>
  </link>

  <link name="wrist_1_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/wrist1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/wrist1.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="1.219"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00255989897604" ixy="0.0" ixz="0.0" iyy="0.00255989897604" iyz="0.0" izz="0.0021942"/>
    </inertial>
  </link>

  <link name="wrist_2_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/wrist2.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="${arm_mesh_dir}/wrist2.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <mass value="1.219"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00255989897604" ixy="0.0" ixz="0.0" iyy="0.00255989897604" iyz="0.0" izz="0.0021942"/>
    </inertial>
  </link>

  <link name="wrist_3_link">
    <inertial>
      <mass value="0.1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="base_link-base_link_inertia" type="fixed">
    <parent link="arm_base_link"/>
    <child link="base_link_inertia"/>
    <origin rpy="0 0 3.14159265359" xyz="0 0 0"/>
  </joint>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link_inertia"/>
    <child link="shoulder_link"/>
    <origin rpy="0 0 3.14159265359" xyz="0 0 0.0596"/>
    <axis xyz="0 0 1"/>
    <limit effort="25.0" lower="-3.14159265359" upper="3.14159265359" velocity="3.14159265359"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin rpy="0 0 0" xyz="0 -0.0606 0.080"/>
    <axis xyz="0 1 0"/>
    <limit effort="25.0" lower="-6.28318530718" upper="6.28318530718" velocity="3.14159265359"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.230"/>
    <axis xyz="0 1 0"/>
    <limit effort="12.5" lower="-3.14159265359" upper="3.14159265359" velocity="3.14159265359"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin rpy="0 0 0" xyz="0 -0.001 0.215"/>
    <axis xyz="0 1 0"/>
    <limit effort="12.5" lower="-6.28318530718" upper="6.28318530718" velocity="3.14159265359"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin rpy="0 0 3.14159265359" xyz="0 -0.0425 0.0375"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.5" lower="-6.28318530718" upper="6.28318530718" velocity="3.14159265359"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin rpy="0 0 0" xyz="0.0375 0 0.043"/>
    <axis xyz="1 0 0"/>
    <limit effort="28.0" lower="-6.28318530718" upper="6.28318530718" velocity="3.14159265359"/>
    <dynamics damping="0" friction="0"/>
  </joint>

  <!-- ==================== Parallel gripper from old_ws ==================== -->
  <joint name="wrist_3_link_to_gripper_base" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="gripper_base"/>
    <origin
      xyz="$(arg gripper_mount_x) $(arg gripper_mount_y) $(arg gripper_mount_z)"
      rpy="$(arg gripper_mount_roll) $(arg gripper_mount_pitch) $(arg gripper_mount_yaw)"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/link5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.160"/>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="gripper_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_left_link"/>
    <origin xyz="0.0817 0.021 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit velocity="4.8" effort="1000" lower="0.000" upper="0.030"/>
    <dynamics damping="0.1"/>
  </joint>

  <link name="gripper_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/gripper_left_palm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/gripper_left_palm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.020"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="gripper_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_right_link"/>
    <origin xyz="0.0817 -0.021 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit velocity="4.8" effort="1000" lower="0.000" upper="0.030"/>
    <dynamics damping="0.1"/>
    <mimic joint="gripper_left_joint" multiplier="1"/>
  </joint>

  <link name="gripper_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/gripper_right_palm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="fr_white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/gripper_right_palm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.020"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="end_effector_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="end_effector_link"/>
    <origin xyz="0.126 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <link name="end_effector_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="fr_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="d405_to_gripper_base" type="fixed">
    <parent link="gripper_base"/>
    <child link="d405"/>
    <origin
      xyz="$(arg d405_x) $(arg d405_y) $(arg d405_z)"
      rpy="$(arg d405_roll) $(arg d405_pitch) $(arg d405_yaw)"/>
  </joint>

  <link name="d405">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/D405.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="fr_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${gripper_mesh_dir}/D405.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.060"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="d405_optical_joint" type="fixed">
    <parent link="d405"/>
    <child link="d405_optical_frame"/>
    <origin xyz="0.023 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="d405_optical_frame"/>

  <xacro:if value="$(arg enable_mobile_hardware)">
    <!-- ==================== ros2_control: mobile ==================== -->
    <ros2_control name="mobile_hardware" type="system">
      <hardware>
        <plugin>mobile_sdk/MobileSystemInterface</plugin>
        <param name="port_front">$(arg port_front)</param>
        <param name="port_rear">$(arg port_rear)</param>
        <param name="front_driver_id">$(arg front_driver_id)</param>
        <param name="rear_driver_id">$(arg rear_driver_id)</param>
        <param name="baudrate">$(arg mobile_baudrate)</param>
        <param name="wheel_radius">0.098</param>
        <param name="wheel_separation">0.32</param>
      </hardware>
      <joint name="front_left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
        <state_interface name="position"/>
      </joint>
      <joint name="front_right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
        <state_interface name="position"/>
      </joint>
      <joint name="rear_left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
        <state_interface name="position"/>
      </joint>
      <joint name="rear_right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="velocity"/>
        <state_interface name="position"/>
      </joint>
    </ros2_control>
  </xacro:if>

  <xacro:if value="$(arg enable_arm_hardware)">
    <!-- ==================== ros2_control: arm ==================== -->
    <ros2_control name="frlab_arm" type="system">
      <hardware>
        <plugin>frlab_manipulator_hardware/FrlabManipulatorHardware</plugin>
        <param name="can_interface">$(arg can_interface)</param>
        <param name="default_velocity">$(arg default_velocity)</param>
        <param name="read_deadline_ms">8</param>
        <param name="read_poll_timeout_ms">2</param>
        <param name="perf_log_every_n_cycles">$(arg arm_perf_log_every_n_cycles)</param>
        <param name="ros_position_offset_wrist_3_joint">$(arg ros_position_offset_wrist_3_joint)</param>
      </hardware>
      <joint name="shoulder_pan_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="shoulder_lift_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="elbow_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="wrist_1_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="wrist_2_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="wrist_3_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
    </ros2_control>
  </xacro:if>

  <xacro:if value="$(arg enable_gripper_hardware)">
    <!-- ==================== ros2_control: gripper ==================== -->
    <ros2_control name="gripper_hardware" type="system">
      <hardware>
        <plugin>gripper_hardware/GripperHardwareInterface</plugin>
        <param name="port">$(arg gripper_port)</param>
        <param name="baudrate">$(arg gripper_baudrate)</param>
        <param name="dxl_id">$(arg gripper_id)</param>
        <param name="ping_on_activate">$(arg gripper_ping_on_activate)</param>
        <param name="min_position">0.000</param>
        <param name="max_position">0.030</param>
        <param name="min_dxl_position">0</param>
        <param name="max_dxl_position">4095</param>
        <param name="calibrate_open_on_activate">true</param>
        <param name="calibrated_open_is_high">true</param>
        <param name="calibrated_close_delta_ticks">900</param>
        <param name="profile_acceleration">10</param>
        <param name="profile_velocity">40</param>
      </hardware>
      <joint name="gripper_left_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
  </xacro:if>

</robot>
