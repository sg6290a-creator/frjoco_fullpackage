<?xml version="1.0"?>
<robot name="frjoco_gripper_only" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="gripper_port" default="/dev/serial/by-id/usb-FTDI_USB__-__Serial_Converter_FTAO4ZHT-if00-port0"/>
  <xacro:arg name="gripper_baudrate" default="1000000"/>
  <xacro:arg name="gripper_id" default="15"/>
  <xacro:arg name="gripper_ping_on_activate" default="false"/>

  <link name="world"/>
  <link name="gripper_base"/>
  <joint name="world_to_gripper_base" type="fixed">
    <parent link="world"/>
    <child link="gripper_base"/>
  </joint>

  <link name="gripper_left_link"/>
  <joint name="gripper_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_left_link"/>
    <origin xyz="0.0817 0.021 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit velocity="4.8" effort="1000" lower="0.020" upper="0.030"/>
    <dynamics damping="0.1"/>
  </joint>

  <ros2_control name="gripper_hardware" type="system">
    <hardware>
      <plugin>gripper_hardware/GripperHardwareInterface</plugin>
      <param name="port">$(arg gripper_port)</param>
      <param name="baudrate">$(arg gripper_baudrate)</param>
      <param name="dxl_id">$(arg gripper_id)</param>
      <param name="ping_on_activate">$(arg gripper_ping_on_activate)</param>
      <param name="min_position">0.020</param>
      <param name="max_position">0.030</param>
      <param name="min_dxl_position">0</param>
      <param name="max_dxl_position">4095</param>
      <param name="calibrate_open_on_activate">true</param>
      <param name="calibrated_open_is_high">true</param>
      <param name="calibrated_close_delta_ticks">500</param>
      <param name="profile_acceleration">10</param>
      <param name="profile_velocity">40</param>
    </hardware>
    <joint name="gripper_left_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
